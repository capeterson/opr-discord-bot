# Discord Bot Token — from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Discord Application Client ID — from the General Information page
DISCORD_CLIENT_ID=your_client_id_here

# Optional: restrict slash command deployment to a single guild (instant updates)
# Leave blank to deploy globally (takes up to 1 hour)
DISCORD_GUILD_ID=

# Supabase project URL — from Settings > API in your Supabase dashboard
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key — from Settings > API
SUPABASE_ANON_KEY=your_supabase_anon_key_here
